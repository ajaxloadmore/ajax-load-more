{
	"name": "ajax-load-more",
	"version": "7.6.0",
	"description": "Ajax Load More WordPress Plugin",
	"scripts": {
		"watch": "npm run dev",
		"dev": "cross-env NODE_ENV=development wp-scripts start",
		"build": "cross-env NODE_ENV=production npm run build:pot && wp-scripts build --config webpack.prod.js",
		"build:pot": "composer run pot",
		"format": "wp-scripts format && composer run format",
		"lint": "run-p lint:*",
		"lint:css": "wp-scripts lint-style --custom-syntax postcss-scss",
		"lint:js": "wp-scripts lint-js",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"lint:php": "composer run lint",
		"deploy": "mkdirp ./_out && npm run build && npm run deploy:files && npm run deploy:dirs",
		"deploy:files": "copyfiles 'ajax-load-more.php' 'README.txt' 'LICENSE.txt' 'uninstall.php' ./_out",
		"deploy:dirs": "copyfiles './admin/**/**/*' './build/**/**/*' './core**/**/*' './lang**/**/*' ./_out",
		"postinstall": "composer install"
	},
	"author": "connekt",
	"private": true,
	"main": "./src/js/ajax-load-more.js",
	"repository": {
		"private": true
	},
	"browserslist": [
		"last 2 versions",
		"ie >= 9",
		"and_chr >= 2.3"
	],
	"dependencies": {
		"crypto-js": "^4.2.0",
		"dompurify": "^3.3.1"
	},
	"devDependencies": {
		"@wordpress/block-editor": "^15.9.0",
		"@wordpress/blocks": "^15.9.0",
		"@wordpress/components": "^30.9.0",
		"@wordpress/data": "^10.36.0",
		"@wordpress/dom-ready": "^4.36.0",
		"@wordpress/i18n": "^6.9.0",
		"@wordpress/scripts": "^31.1.0",
		"@wordpress/server-side-render": "^6.12.0",
		"axios": "^1.13.2",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^13.0.1",
		"cross-env": "^10.1.0",
		"css-loader": "^7.1.2",
		"css-minimizer-webpack-plugin": "^7.0.3",
		"eslint-webpack-plugin": "^5.0.2",
		"imagesloaded": "^5.0.0",
		"mini-css-extract-plugin": "^2.9.4",
		"mkdirp": "^3.0.1",
		"npm-run-all": "^4.1.5",
		"postcss-import": "^16.1.1",
		"postcss-loader": "^8.2.0",
		"postcss-preset-env": "^10.5.0",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.7.4",
		"qs": "^6.14.0",
		"sass": "^1.95.1",
		"sass-loader": "^16.0.6",
		"style-loader": "^4.0.0",
		"stylelint-config-prettier": "^9.0.5",
		"stylelint-webpack-plugin": "^5.0.1",
		"webpack-cli": "^6.0.1",
		"webpack-merge": "^6.0.1"
	}
}